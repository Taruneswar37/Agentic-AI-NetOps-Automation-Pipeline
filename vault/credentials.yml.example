# ═══════════════════════════════════════════════════════════
# Ansible Vault Credentials — EXAMPLE
# ═══════════════════════════════════════════════════════════
# Copy this file to credentials.yml and encrypt it:
#   ansible-vault encrypt vault/credentials.yml
#
# These variables are referenced in generated playbooks as:
#   {{ vault_device_username }}
#   {{ vault_device_password }}
#   {{ vault_enable_password }}
# ═══════════════════════════════════════════════════════════

# Device SSH credentials
vault_device_username: "netops-admin"
vault_device_password: "REPLACE_WITH_REAL_PASSWORD"
vault_enable_password: "REPLACE_WITH_ENABLE_PASSWORD"

# SNMP community strings
vault_snmp_ro_community: "REPLACE_RO_COMMUNITY"
vault_snmp_rw_community: "REPLACE_RW_COMMUNITY"
